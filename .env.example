# Deployment environment. Valid: development, test, staging, production.
# When set to staging or production, Settings refuses to boot if known-weak
# sample values for SIGNALCLAW_API_KEY or SIGNALCLAW_DASHBOARD_PASSWORD are
# present, or if either is shorter than 16 characters.
SIGNALCLAW_ENV=development
SIGNALCLAW_API_KEY=change-me-local-dev-only
SIGNALCLAW_DASHBOARD_PASSWORD=change-me
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
NEWSAPI_KEY=
LOG_LEVEL=INFO
DATA_DIR=./data
ENABLE_CI=false
# OpenTelemetry tracing. Leave OTEL_EXPORTER_OTLP_ENDPOINT empty to
# disable export (tracer is still installed as a no-op, so app code
# that creates spans keeps working). When set, point at a collector
# base URL (for example http://otel-collector:4318); the OTLP/HTTP
# exporter will append /v1/traces if missing.
OTEL_EXPORTER_OTLP_ENDPOINT=
# Parent-based ratio sampler in [0.0, 1.0]. Defaults to 1.0 (record
# everything) which is fine for dev. Lower in production.
OTEL_TRACES_SAMPLER_ARG=1.0
# Optional override for the service.version resource attribute.
OTEL_SERVICE_VERSION=
# Sentry error tracking. Leave SENTRY_DSN empty to disable (default).
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=false
# RBAC scope enforcement. Set to 0 to disable the global scope
# middleware and fall back to the legacy permissive single-key model.
SIGNALCLAW_RBAC_ENFORCE=1
# Optional multi-key registry. JSON list of
#   {"key":"...","scopes":["read","trade","admin"],"label":"...","rate_per_minute":120}
# When unset the legacy SIGNALCLAW_API_KEY above is used and granted read+trade.
SIGNALCLAW_API_KEYS_JSON=
# Per-IP DoS guard. Token bucket capacity + refill, in requests per
# minute per source IP. Set to 0 to disable (not recommended for any
# public exposure). Composes with the per-key limiter above.
SIGNALCLAW_PER_IP_PER_MIN=600
# Trust X-Forwarded-For / X-Real-IP when computing the source IP.
# Off by default so direct attackers cannot spoof the header. Turn
# on only when running behind a known reverse proxy or ingress.
SIGNALCLAW_TRUST_FORWARDED=0
# Comma-separated allowlist of peer IPs whose forwarded headers will
# be honoured. Required when SIGNALCLAW_TRUST_FORWARDED=1 to avoid
# trusting arbitrary callers.
SIGNALCLAW_TRUSTED_PROXIES=
# Audit log retention. Maximum age in UTC days for files under
# <data_dir>/audit/. Files older than this are deleted by a background
# sweeper. Set to 0 to disable retention (keep forever, not
# recommended). Sweep cadence is controlled by
# SIGNALCLAW_AUDIT_RETENTION_INTERVAL_SECONDS (default 3600).
SIGNALCLAW_AUDIT_RETENTION_DAYS=90
SIGNALCLAW_AUDIT_RETENTION_INTERVAL_SECONDS=3600
