SIGNALCLAW_API_KEY=change-me-local-dev-only
SIGNALCLAW_DASHBOARD_PASSWORD=change-me
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
NEWSAPI_KEY=
LOG_LEVEL=INFO
DATA_DIR=./data
ENABLE_CI=false
OTEL_EXPORTER_OTLP_ENDPOINT=
# Sentry error tracking. Leave SENTRY_DSN empty to disable (default).
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=false
# RBAC scope enforcement. Set to 0 to disable the global scope
# middleware and fall back to the legacy permissive single-key model.
SIGNALCLAW_RBAC_ENFORCE=1
# Optional multi-key registry. JSON list of
#   {"key":"...","scopes":["read","trade","admin"],"label":"...","rate_per_minute":120}
# When unset the legacy SIGNALCLAW_API_KEY above is used and granted read+trade.
SIGNALCLAW_API_KEYS_JSON=
